name = "pmo-documentation-hub"
main = "cloudflare-worker.js"
compatibility_date = "2026-05-07"

[vars]
GITHUB_OWNER = "bombpartyPMO"
GITHUB_REPO = "bp-pmo-documentation-hub"
GITHUB_BRANCH = "main"
GITHUB_DATA_PATH = "data/documentation-data.json"

# Store this as a Cloudflare Worker secret, not a plain var:
# wrangler secret put GITHUB_TOKEN
